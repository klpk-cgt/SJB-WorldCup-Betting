# ============================================
# 项目环境变量配置示例
# 复制此文件为 .env 并填写真实值
# .env 文件不要提交到 Git
# ============================================

# ----- 基础配置 -----
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
DISABLE_HMR=false
APP_STORAGE_MODE=json
APP_DATA_DIR=.
DATABASE_URL=

# ----- 第三方数据源 -----
# API-Football（赛程数据）
API_FOOTBALL_KEY=

# The Odds API（实时赔率）
THE_ODDS_API_KEY=

# ----- AI 提供商 -----
# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro

# Gemini
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image-preview

# Mimo
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_DEFAULT_MODEL=mimo-v2.5-pro
MIMO_MULTIMODAL_MODEL=mimo-v2.5
MIMO_FAST_MODEL=mimo-v2-flash

# AI 路由配置
AI_PRIMARY_PROVIDER=deepseek
AI_FALLBACK_PROVIDER=mimo
AI_ENABLE_WEB_SEARCH=true
AI_ENABLE_MULTIMODAL=true
AI_CACHE_TTL_MINUTES=30

# ----- 管理员配置 -----
ADMIN_USERNAME=admin
# 生产环境必须修改！
ADMIN_PASSWORD=admin_worldcup2026
ADMIN_SESSION_TTL_MS=43200000

# ----- 业务配置 -----
PREDICTION_LOCK_MINUTES=5
SYNC_INTERVAL_MINUTES=5

# ----- 数据配置 -----
# 动态时间线最大保留条数
ACTIVITY_MAX_ENTRIES=1000
# 动态归档文件名
ACTIVITY_ARCHIVE_FILE=db.activities.archive.json
